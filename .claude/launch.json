{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "lip-ui",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const net=require('net');const port=process.env.PORT||3999;net.createServer(c=>{const u=net.connect(3000,'127.0.0.1');c.pipe(u);u.pipe(c);c.on('error',()=>u.destroy());u.on('error',()=>c.destroy());}).listen(port,()=>console.log('tcp proxy :'+port+' -> :3000'));"
      ],
      "autoPort": true
    }
  ]
}
